    <script>
        // Tailwind script already included via CDN
        
        function navigateTo(section) {
            document.getElementById(section).scrollIntoView({ behavior: "smooth" });
        }
        
        // Progress bar
        window.addEventListener('scroll', () => {
            const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const scrolled = (winScroll / height) * 100;
            document.getElementById("progress-bar").style.width = scrolled + "%";
        });
        
        function toggleSearch() {
            const modal = document.getElementById('search-modal');
            modal.classList.toggle('hidden');
            setTimeout(() => {
                document.getElementById('search-input').focus();
            }, 300);
        }
        
        function subscribeModal() {
            alert("Thank you. In a real deployment this would open a beautiful newsletter / community signup with early access to the private forum.");
        }
        
        function viewArticle(id) {
            const titles = {
                1: "Week 14: Jaw surgery consultation",
                2: "Connecting African Philosophy...",
                3: "Building in public: My first AI agent"
            };
            alert(`Opening full article: ${titles[id]}\n\n(This would expand into a beautiful reading experience with side annotations and progress tracking in the final build.)`);
        }
        
        function fakeSearch(el) {
            alert("Search would filter and display results instantly.\n\nResult: " + el.textContent);
            document.getElementById('search-modal').classList.add('hidden');
        }
        
        // Keyboard shortcuts
        document.addEventListener('keydown', function(e) {
            if (e.key === '/' && document.getElementById('search-modal').classList.contains('hidden')) {
                e.preventDefault();
                toggleSearch();
            }
            if (e.key === "Escape") {
                document.getElementById('search-modal').classList.add('hidden');
            }
        });
        
        // Initialize
        console.log('%cHansei Dev — Built with radical intention', 'color: #67e8f9; font-family: monospace');
        
        // Make cards more interactive
        setTimeout(() => {
            document.querySelectorAll('.card-hover').forEach((card, i) => {
                card.style.transitionDelay = (i * 80) + 'ms';
            });
        }, 1200);
    </script>
